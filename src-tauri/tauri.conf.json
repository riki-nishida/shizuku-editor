{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shizuku Editor",
  "version": "1.0.0",
  "identifier": "com.shizuku.editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Shizuku Editor",
        "width": 1400,
        "height": 880,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "appimage",
      "deb"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Riki Nishida",
    "copyright": "© 2026 Riki Nishida",
    "homepage": "https://github.com/riki-nishida/shizuku-editor",
    "category": "Productivity",
    "shortDescription": "A writing editor for novelists",
    "longDescription": "A desktop application designed for novel writing",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzNjRENUZFQzY3RjZEMkYKUldRdmJYL0cvdFZrTTVRSmRZdkVoc3dZWkcvbjVKNjY0TFdEektkeFZKcldVV0xhQmJHVjJPdDgK",
      "endpoints": [
        "https://github.com/riki-nishida/shizuku-editor/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"tauri:build:signed": "./scripts/local-build.sh",
		"tauri:build:win:signed": "./scripts/local-build.sh --runner cargo-xwin --target x86_64-pc-windows-msvc",
